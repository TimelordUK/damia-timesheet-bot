// Damia bot — a NEW-TAB layout (not a full session layout). Mirrors the structure of the
// user's real session layout (tab-bar / main / status-bar / floating_panes; start_suspended).
//
// Add it to a RUNNING zellij session (keeps your default layout + plugins intact):
//     zellij action new-tab --layout zellij/damia-tab.kdl --name damia
// or run  scripts/damia-tab.ps1  from inside zellij.
//
// A `new-tab --layout` does NOT inherit your new_tab_template, so this tab declares the
// tab-bar (size=1) and status-bar (size=1) plugin panes itself — without them the tab
// renders bare and you lose the navigation chrome.
//
// Main area = the dashboard (TUI, top) + the bot agent (poll loop, bottom strip), side by side:
//   * timesheet : the Textual TUI — the live state board. Runs immediately, reads
//                 %LOCALAPPDATA%\damia-timesheet-bot\cache\view.json (auto-refreshes every 3s).
//   * bot-agent : `damia-bot poll` — the autonomous workflow loop. start_suspended, so press
//                 ENTER in the pane to START it AFTER the debug Chrome is up and you're logged
//                 into Damia. It NEVER sends and NEVER submits — it drafts + attaches only.
// Floating panes (start_suspended, hidden by default — toggle with your floating-panes keybind):
//   * chrome-cdp : Chrome with the CDP debug port + dedicated profile + Damia (the 136+ quirk).
//                  START THIS FIRST and log into Damia, THEN start the bot-agent pane.
//   * hydrator   : `damia-bot hydrate` — force a full portal re-walk on demand.
layout {
    cwd "C:\\Users\\sjame\\dev\\damia-timesheet-bot"
    tab name="damia" focus=true hide_floating_panes=true {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        pane split_direction="horizontal" {
            pane name="timesheet" command="uv" {
                args "run" "damia-bot" "tui"
            }
            pane name="bot-agent" size="32%" command="uv" {
                start_suspended true
                args "run" "damia-bot" "poll" "--interval" "120"
            }
        }
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
        floating_panes {
            pane name="chrome-cdp" command="C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe" {
                start_suspended true
                height 32
                width 84
                x 42
                y 17
                args "--remote-debugging-port=9222" "--user-data-dir=C:\\Users\\sjame\\AppData\\Local\\damia-timesheet-bot\\chrome-profile" "https://damia.timesheetportal.com/"
            }
            pane name="hydrator" command="uv" {
                start_suspended true
                height 14
                width 84
                x 42
                y 2
                args "run" "damia-bot" "hydrate"
            }
        }
    }
}
